# ---------- Cloudflare Tunnel ----------
CLOUDFLARE_TUNNEL_TOKEN=

# ---------- Supabase ----------
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:senha@db_host:5432/postgres

# ---------- Ops API admin auth ----------
OPS_ADMIN_SERVICE_TOKEN=troque-por-um-token-forte

# ---------- NOC Panel Auth (Security) ----------
NOC_ADMIN_PASSWORD=troque-por-senha-forte
NOC_SESSION_SECRET=troque-por-segredo-hmac-forte-32chars

# ---------- Cloudflare DNS automation (optional) ----------
# Leave these empty when tenant subdomains are managed manually
# with Cloudflare Redirect Rules.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
SAAS_TARGET_IP=168.138.159.251

# ---------- R2 (Cloudflare Object Storage) ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=legislativo-backups
R2_PUBLIC_BASE_URL=

# ---------- Telegram Alerts ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- Panel runtime ----------
# Use internal Docker hostname for server-to-server calls (avoids Cloudflare roundtrip)
OPS_API_URL=http://ops-api:4000
# This is used on the client-side browser for any public API calls (keep external URL)
NEXT_PUBLIC_NOC_API_URL=https://api.rtectecnologia.com.br
